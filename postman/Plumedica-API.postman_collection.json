{
  "info": {
    "name": "Plumedica API v2",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://plumedica-task.onrender.com" },
    { "key": "adminToken", "value": "" },
    { "key": "doctorMongoId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Doctor",
          "request": {
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Vikram Naidu\",\n  \"email\": \"newdoctor@example.com\",\n  \"mobile\": \"9090909090\",\n  \"password\": \"vikram@123\",\n  \"qualification\": \"MBBS\",\n  \"experience\": \"5 Years\",\n  \"clinicAddress\": \"Tirupati\",\n  \"specialization\": \"Dermatology\",\n  \"licenseNumber\": \"LIC9901\",\n  \"availability\": \"Mon-Sat\"\n}"
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login Doctor",
          "request": {
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"srikanthparimisetty93@gmail.com\",\n  \"password\": \"aarav@123\"\n}"
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }]
      },
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@plumedica.com\",\n  \"password\": \"Plumedica@admin123\"\n}"
            },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/admin/login"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["pm.collectionVariables.set('adminToken', pm.response.json().token);"]
            }
          }]
        },
        {
          "name": "Get Doctors",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/admin/doctors" },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const d = pm.response.json().doctors.find(x => x.status === 'PENDING');",
                "if (d) pm.collectionVariables.set('doctorMongoId', String(d._id).trim());"
              ]
            }
          }]
        },
        {
          "name": "Approve Doctor",
          "request": { "method": "PUT", "url": "{{baseUrl}}/api/admin/approve/{{doctorMongoId}}" }
        },
        {
          "name": "Reject Doctor",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"rejectionReason\": \"Incomplete documents\"\n}" },
            "url": "{{baseUrl}}/api/admin/reject/{{doctorMongoId}}"
          }
        }
      ]
    }
  ]
}
